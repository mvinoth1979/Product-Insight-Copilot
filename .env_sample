# =========================================================================
# InsightFlow Configuration Environment Template (.env_sample)
# Rename this file to .env.local for local Next.js execution.
# Do not commit your actual credentials to version control.
# =========================================================================

# LLM Reasoning Services
GEMINI_API_KEY=
GROQ_API_KEY=

# Notion Integration (MCP Sync Target 1)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Google OAuth2 Credentials (MCP Sync Target 2: Gmail Draft Creator)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# (Optional) Google Play Store Scraper Crawler Configuration
# For live scraping (requires google-play-scraper package or local crawler services)
GOOGLE_PLAY_APP_ID=

